---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="How to Order — San Anselmo Publications, Inc."
  description="How to order books from San Anselmo Publications. GCash, bank transfer, and cash on delivery. Nationwide delivery."
  dataPage="order"
  prefetchHrefs={['index.html']}
>
  <div class="page-body">
    <main class="main-content" id="mainContent" role="main">
      <section class="content-section active" aria-label="How to Order">
        <div class="section-inner">
          <header class="page-header">
            <h1 class="page-title">How to <span class="accent">Order</span></h1>
            <p class="page-subtitle">
              Every purchase supports independent Filipino publishing
            </p>
          </header>

          <div class="order-accordion" id="orderAccordion">
            <!-- Accordion Item 1 -->
            <div class="accordion-item">
              <h2>
                <button
                  class="accordion-header"
                  aria-expanded="false"
                  aria-controls="panel1"
                >
                  <span class="acc-step-num">1</span>
                  <span class="acc-step-title">Browse &amp; Build Your Cart</span>
                  <svg class="icon acc-chevron" aria-hidden="true"
                    ><use href="#icon-chevron"></use></svg
                  >
                </button>
              </h2>
              <div class="accordion-panel" id="panel1">
                <div class="acc-content">
                  <p class="acc-intro-text">
                    Explore our collection of exceptional Philippine literature,
                    poetry, history, and socio-political works. Every purchase
                    directly supports independent publishing in the Philippines.
                  </p>
                  <div class="order-minimal-grid">
                    <div class="min-card">
                      <div class="min-card-icon" aria-hidden="true">
                        <svg><use href="#icon-cart"></use></svg>
                      </div>
                      <h3 class="min-card-title">Print Editions</h3>
                      <p class="min-card-desc">
                        Browse our <a href="index.html" class="min-card-link"
                          >catalog</a
                        > and add books to your shopping cart. Standard checkouts
                        generate an order slip to complete via Messenger.
                      </p>
                    </div>
                    <div class="min-card">
                      <div class="min-card-icon" aria-hidden="true">
                        <svg><use href="#icon-book"></use></svg>
                      </div>
                      <h3 class="min-card-title">Digital eBooks</h3>
                      <p class="min-card-desc">
                        Look for the "Buy Digital Edition" button on eligible
                        titles. This lets you purchase and download the PDF/EPUB
                        version instantly via Gumroad.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Accordion Item 2 -->
            <div class="accordion-item">
              <h2>
                <button
                  class="accordion-header"
                  aria-expanded="false"
                  aria-controls="panel2"
                >
                  <span class="acc-step-num">2</span>
                  <span class="acc-step-title">Payment Options</span>
                  <svg class="icon acc-chevron" aria-hidden="true"
                    ><use href="#icon-chevron"></use></svg
                  >
                </button>
              </h2>
              <div class="accordion-panel" id="panel2">
                <div class="acc-content">
                  <p class="acc-intro-text">
                    We offer multiple convenient and secure payment options.
                    Select your preferred channel during checkout.
                  </p>
                  <div class="order-minimal-grid">
                    <div class="min-card">
                      <div class="min-card-icon" aria-hidden="true">
                        <svg><use href="#icon-qr"></use></svg>
                      </div>
                      <h3 class="min-card-title">GCash Wallet</h3>
                      <p class="min-card-desc">
                        Instant and fee-free transfers. Scan our corporate
                        merchant QR code or transfer directly to our registered
                        number to be sent privately.
                      </p>
                    </div>
                    <div class="min-card">
                      <div class="min-card-icon" aria-hidden="true">
                        <svg><use href="#icon-document"></use></svg>
                      </div>
                      <h3 class="min-card-title">Bank Transfer</h3>
                      <p class="min-card-desc">
                        Direct deposits or secure online transfers to our BPI or
                        BDO corporate accounts.
                      </p>
                    </div>
                    <div class="min-card">
                      <div class="min-card-icon" aria-hidden="true">
                        <svg><use href="#icon-delivery"></use></svg>
                      </div>
                      <h3 class="min-card-title">Cash on Delivery</h3>
                      <p class="min-card-desc">
                        Pay cash directly to our partner couriers upon doorstep
                        delivery. Nationwide coverage with no upfront fees
                        required.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Accordion Item 3 -->
            <div class="accordion-item">
              <h2>
                <button
                  class="accordion-header"
                  aria-expanded="false"
                  aria-controls="panel3"
                >
                  <span class="acc-step-num">3</span>
                  <span class="acc-step-title">Fulfillment &amp; Shipping</span>
                  <svg class="icon acc-chevron" aria-hidden="true"
                    ><use href="#icon-chevron"></use></svg
                  >
                </button>
              </h2>
              <div class="accordion-panel" id="panel3">
                <div class="acc-content">
                  <p class="acc-intro-text">
                    Your order is prepared at our office. Shipping charges are
                    calculated at cost based on your location.
                  </p>
                  <div class="order-minimal-grid">
                    <div class="min-card">
                      <div class="min-card-icon" aria-hidden="true">
                        <svg><use href="#icon-mail"></use></svg>
                      </div>
                      <h3 class="min-card-title">Digital eBooks</h3>
                      <p class="min-card-desc">
                        Instant dispatch to your email inbox immediately upon
                        Gumroad payment.
                      </p>
                    </div>
                    <div class="min-card">
                      <div class="min-card-icon" aria-hidden="true">
                        <svg><use href="#icon-send"></use></svg>
                      </div>
                      <h3 class="min-card-title">Same-Day Delivery</h3>
                      <p class="min-card-desc">
                        Available for Metro Manila orders placed before 2:00 PM.
                        Dispatched via LBC or Lalamove at cost.
                      </p>
                    </div>
                    <div class="min-card">
                      <div class="min-card-icon" aria-hidden="true">
                        <svg><use href="#icon-pin"></use></svg>
                      </div>
                      <h3 class="min-card-title">Standard Nationwide</h3>
                      <p class="min-card-desc">
                        Provincial shipping sent via J&T Express or LBC Express.
                        Standard transit takes 3 to 7 working days; tracking
                        provided.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
